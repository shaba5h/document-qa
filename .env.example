# --- Required ---

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free

# --- Embedding Model ---

# HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HUGGINGFACE_DEVICE=cpu

# --- ChromaDB ---

# CHROMA_PERSIST_DIRECTORY=./chroma
# CHROMA_COLLECTION_NAME=documents

# --- LLM ---

# OPENROUTER_TEMPERATURE=0.0

# --- Retriever ---

# RETRIEVER_K=3
# RETRIEVER_SCORE_THRESHOLD=1.5

# --- Splitter ---

# SPLITTER_CHUNK_SIZE=1000
# SPLITTER_CHUNK_OVERLAP=200
# SPLITTER_ADD_START_INDEX=true

# --- Indexer ---

# INDEXER_BATCH_SIZE=50

# --- Agent ---

# AGENT_SYSTEM_PROMPT=You are an assistant with access to a knowledge base. Use the retrieve_context tool to search for information before answering. If the knowledge base does not contain the answer, say so honestly.
